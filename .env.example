# Copiá este archivo a .env y completá los valores. NO commitees .env.

# --- Stellar / Soroban ---
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Identidad de despliegue (creada con `stellar keys generate`)
STELLAR_SOURCE_ACCOUNT=
# ID del contrato verificador una vez desplegado
KYC_VERIFIER_CONTRACT_ID=

# --- Issuer mock ---
# Clave del issuer que firma credenciales de prueba (mock — no usar en prod)
ISSUER_SIGNING_KEY=

# --- Frontend (web/) ---
# Las variables expuestas al cliente deben empezar con VITE_
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
VITE_KYC_VERIFIER_CONTRACT_ID=
