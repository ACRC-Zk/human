{
  "name": "behuman",
  "version": "0.0.0",
  "private": true,
  "description": "beHuman — KYC con Zero-Knowledge sobre Stellar (proof of personhood)",
  "license": "UNLICENSED",
  "workspaces": [
    "web",
    "packages/*",
    "identity/issuer",
    "platform/api",
    "platform/curation"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:tdd": "npm run test --workspace @behuman/web",
    "typecheck:tdd": "npm run typecheck --workspace @behuman/web",
    "setup:hooks": "bash scripts/setup-pre-commit.sh",
    "pre-commit": "npm run typecheck:tdd && npm run lint --workspace @behuman/web && npm run test:tdd"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "shadcn": "^4.11.0"
  }
}
