{
  "name": "@behuman/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Frontend de beHuman — landing y auth (React + Vite + TS)",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
